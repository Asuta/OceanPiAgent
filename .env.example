OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PROVIDER_MODE=auto
HTTPS_PROXY=
HTTP_PROXY=
OCEANKING_AGENT_WORKSPACE_ALLOW_OUTSIDE=false

# Optional Feishu channel runtime
# FEISHU_ENABLED=true
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=your_feishu_app_secret_here
# FEISHU_DEFAULT_AGENT_ID=concierge
# FEISHU_ALLOW_OPEN_IDS=ou_xxx,ou_yyy
# FEISHU_REACTION_ACK=OK
# FEISHU_REACTION_DONE=DONE

# Optional native pi-ai providers
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
